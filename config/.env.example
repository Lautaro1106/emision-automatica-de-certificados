# ============================================
# CONFIGURACIÓN DEL SISTEMA DE CERTIFICADOS
# ============================================
#
# Este archivo contiene todas las variables de configuración necesarias.
# 
# INSTRUCCIONES:
# 1. Copiar este archivo como ".env" (sin .example)
# 2. Reemplazar TODOS los valores YOUR_* con tus datos reales
# 3. NUNCA commitear el archivo .env a Git
#

# --------------------------------------------
# n8n CONFIGURATION
# --------------------------------------------

# URL completa del webhook de n8n
# Obtenerlo de: n8n → Workflow activo → Nodo "Webhook" → Production URL
# Ejemplo: https://n8n.midominio.com/webhook/generar-certificados
N8N_WEBHOOK_URL=YOUR_N8N_WEBHOOK_URL

# API Key para autenticación del webhook
# Debe coincidir EXACTAMENTE con el "Value" en la credencial "Header Auth" de n8n
# Generar una contraseña fuerte, ejemplo: Cert2025!Secure#Key789
N8N_API_KEY=YOUR_API_KEY_HERE


# --------------------------------------------
# GOOGLE CLOUD PLATFORM
# --------------------------------------------

# ID del proyecto en Google Cloud Console
# Obtenerlo de: console.cloud.google.com → Selector de proyecto
GCP_PROJECT_ID=YOUR_GCP_PROJECT_ID

# OAuth 2.0 Client ID
# Obtenerlo de: GCP → APIs y servicios → Credenciales
# Formato: XXXXXXXXX-YYYYYYYY.apps.googleusercontent.com
GCP_CLIENT_ID=YOUR_CLIENT_ID

# OAuth 2.0 Client Secret
# Obtenerlo de: GCP → APIs y servicios → Credenciales
# Formato: GOCSPX-XXXXXXXXXXXXXXXX
GCP_CLIENT_SECRET=YOUR_CLIENT_SECRET


# --------------------------------------------
# GOOGLE WORKSPACE - RESOURCES
# --------------------------------------------

# ID del Google Sheet con la lista de certificados
# Obtenerlo de la URL: docs.google.com/spreadsheets/d/[ESTE_ES_EL_ID]/edit
GOOGLE_SHEET_ID=YOUR_GOOGLE_SHEET_ID

# Nombre de la hoja dentro del Sheet (por defecto: primera hoja)
GOOGLE_SHEET_NAME=SOLO TOCAR (SI/NO)

# ID de la plantilla de Google Slides
# Obtenerlo de la URL: docs.google.com/presentation/d/[ESTE_ES_EL_ID]/edit
GOOGLE_SLIDES_TEMPLATE_ID=YOUR_TEMPLATE_SLIDE_ID

# ID de la carpeta de Google Drive donde se guardarán los PDFs
# Obtenerlo de la URL: drive.google.com/drive/folders/[ESTE_ES_EL_ID]
GOOGLE_DRIVE_FOLDER_ID=YOUR_DRIVE_FOLDER_ID


# --------------------------------------------
# EMAIL CONFIGURATION
# --------------------------------------------

# Email desde el cual se enviarán los certificados
# Debe ser la cuenta autorizada en las credenciales OAuth de n8n
SENDER_EMAIL=certificados@tudominio.com

# Nombre que aparecerá como remitente
SENDER_NAME=Sistema de Certificados

# Asunto del email (puede incluir variables)
EMAIL_SUBJECT=Certificado de Asistencia: {{ACTIVIDAD}}


# --------------------------------------------
# WORKFLOW SETTINGS
# --------------------------------------------

# Tiempo de espera entre certificados (en segundos)
# Default: 5 segundos
# Reducir para mayor velocidad (min: 2s)
# Aumentar si hay errores de cuota (max: 10s)
WAIT_TIME_SECONDS=5

# Modo de operación
# - production: Procesa y envía todo
# - test: Solo procesa sin enviar emails
# - debug: Logs extendidos
MODE=production


# --------------------------------------------
# SECURITY (OPTIONAL)
# --------------------------------------------

# Lista de emails autorizados para ejecutar el workflow (separados por coma)
# Dejar vacío para permitir a todos
# Ejemplo: admin@empresa.com,usuario@empresa.com
AUTHORIZED_USERS=

# IP whitelisting para webhook (separadas por coma)
# Dejar vacío para permitir todas
WEBHOOK_ALLOWED_IPS=


# --------------------------------------------
# LOGGING AND MONITORING (OPTIONAL)
# --------------------------------------------

# Nivel de logging
# - error: Solo errores
# - warn: Errores y advertencias
# - info: Información general (default)
# - debug: Información detallada
LOG_LEVEL=info

# Webhook para notificaciones (Slack, Discord, etc.)
# Dejar vacío para deshabilitar
NOTIFICATION_WEBHOOK_URL=


# --------------------------------------------
# DEVELOPMENT / TESTING
# --------------------------------------------

# Usar ambiente de desarrollo
# true: Usa recursos de testing
# false: Usa recursos de producción
DEV_MODE=false

# Sheet de prueba (solo si DEV_MODE=true)
DEV_GOOGLE_SHEET_ID=

# Folder de prueba (solo si DEV_MODE=true)
DEV_DRIVE_FOLDER_ID=


# ============================================
# NOTAS IMPORTANTES
# ============================================
#
# 1. Este archivo NO debe ser commiteado a Git
#    - Está incluido en .gitignore
#    - Contiene información sensible
#
# 2. Backup de este archivo
#    - Guardar copia segura en gestor de contraseñas
#    - O en almacenamiento encriptado
#
# 3. Rotar credenciales regularmente
#    - API Keys: cada 6 meses
#    - OAuth tokens: auto-refresh
#
# 4. Verificar que TODAS las variables estén configuradas
#    - Ejecutar: grep "YOUR_" .env
#    - No debe retornar ninguna línea
#
# ============================================
